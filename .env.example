# ═══════════════════════════════════════════════════════════════════════════════
# CV Screening Chatbot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Gemini API (REQUIRED) ─────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for chat responses (gemini-1.5-flash is fast & cost-effective)
GEMINI_LLM_MODEL=gemini-1.5-flash

# Gemini embedding model
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ─── ChromaDB Vector Store ─────────────────────────────────────────────────────
# Directory where ChromaDB persists its data
CHROMA_PERSIST_DIR=./chatbot/vectorstore/chroma_db

# Name of the ChromaDB collection
CHROMA_COLLECTION_NAME=cv_screening_kb

# ─── Document Ingestion ────────────────────────────────────────────────────────
# Root directory containing category subdirectories (faq/, services/, etc.)
DOCUMENTS_DIR=./chatbot/documents

# Text chunk size in characters
CHUNK_SIZE=800

# Overlap between consecutive chunks
CHUNK_OVERLAP=150

# ─── RAG Retrieval ────────────────────────────────────────────────────────────
# Number of chunks to retrieve per query
RETRIEVAL_TOP_K=5

# Minimum relevance score (0.0–1.0) to include a chunk
RETRIEVAL_SCORE_THRESHOLD=0.3

# ─── Conversation Memory ──────────────────────────────────────────────────────
# Maximum number of conversation turns to remember per session
MAX_HISTORY_TURNS=10

# ─── API Server ───────────────────────────────────────────────────────────────
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8001

# Comma-separated list of allowed CORS origins
# Add your CV screening frontend origin here
CHATBOT_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
